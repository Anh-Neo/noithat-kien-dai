---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { servicePages } from "../../data/sitePages.js";
---

<BaseLayout
  title="Dịch vụ thiết kế, sản xuất và thi công nội thất | Kiến Đại"
  description="Kiến Đại cung cấp thiết kế 3D, sản xuất nội thất tại xưởng, thi công trọn gói, tủ bếp, tủ áo và hệ lưu trữ gỗ công nghiệp tại Hà Nội."
  canonical="/dich-vu/"
  ogImage="/assets/service-3d.webp"
  preloadHeroImages={false}
>
  <main id="main" class="content-main">
    <PageHero
      eyebrow="Dịch vụ"
      title="Thiết kế, sản xuất và thi công nội thất trọn gói"
      description="Một quy trình liền mạch từ khảo sát, thiết kế 3D, sản xuất tại xưởng đến lắp đặt hoàn thiện cho căn hộ, nhà phố, khách lẻ gia đình và văn phòng."
      image="/assets/service-3d.webp"
      imageAlt="Không gian thiết kế nội thất 3D hiện đại"
      stats={["Thiết kế 3D", "Xưởng trực tiếp", "Thi công nhanh"]}
    />

    <section class="section content-section" aria-labelledby="services-title">
      <div class="section-heading">
        <div>
          <div class="section-kicker">Dịch vụ chính</div>
          <h2 id="services-title">Chọn đúng dịch vụ theo nhu cầu hiện tại</h2>
        </div>
        <p>Mỗi dịch vụ có trang riêng với nội dung, hình ảnh, quy trình và mẫu tham khảo để khách hàng dễ ra quyết định.</p>
      </div>
      <div class="content-card-grid service-overview-grid">
        {servicePages.map((service) => (
          <article class="service-overview-card reveal">
            <a class="service-overview-media" href={`/dich-vu/${service.slug}/`}>
              <img src={service.image} width="760" height="570" alt={service.imageAlt} loading="lazy" decoding="async">
            </a>
            <div>
              <span>{service.eyebrow}</span>
              <h2><a href={`/dich-vu/${service.slug}/`}>{service.title}</a></h2>
              <p>{service.summary}</p>
              <a class="text-link" href={`/dich-vu/${service.slug}/`}>Xem chi tiết</a>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
